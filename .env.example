# =============================================================================
# cultivation-intelligence — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# Generate SECRET_KEY with: openssl rand -hex 32
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true
LOG_LEVEL=INFO
SECRET_KEY=changeme-use-openssl-rand-hex-32

# ---------------------------------------------------------------------------
# Database (TimescaleDB — PostgreSQL with time-series extension)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://cultivation:cultivation@localhost:5432/cultivation_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=false

# ---------------------------------------------------------------------------
# Redis (task queue + caching)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL_SECONDS=300

# ---------------------------------------------------------------------------
# Home Assistant Integration
# ---------------------------------------------------------------------------
HA_BASE_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_access_token_here
HA_WEBSOCKET_URL=ws://homeassistant.local:8123/api/websocket
HA_VERIFY_SSL=false
HA_POLL_INTERVAL_SECONDS=30
HA_RECONNECT_DELAY_SECONDS=5
HA_MAX_RECONNECT_ATTEMPTS=10

# ---------------------------------------------------------------------------
# AquaPro Dosing Controller (EC / pH management)
# Device serial number on the unit label.
# Entity prefix is auto-derived but can be overridden.
# ---------------------------------------------------------------------------
AQUAPRO_DEVICE_SERIAL=AQU1AD04A42
AQUAPRO_ENTITY_PREFIX=sensor.aquapro_aq1ad04a42

# ---------------------------------------------------------------------------
# ESPHome / Zigbee Sensor Entity IDs
# Comma-separated lists consumed by the ingest service.
# ---------------------------------------------------------------------------
ESPHOME_SENSOR_ENTITIES=sensor.tent_1_sht31_temperature,sensor.tent_1_sht31_humidity,sensor.tent_2_sht31_temperature,sensor.tent_2_sht31_humidity
ZIGBEE_SOIL_ENTITIES=sensor.growzone_a_vwc,sensor.growzone_b_vwc,sensor.growzone_c_vwc
ZIGBEE_CO2_ENTITIES=sensor.inline_co2_ppm
LIGHTING_ENTITIES=switch.gavita_e906_tent_1,switch.gavita_e906_tent_2,sensor.dli_cumulative_tent_1,sensor.dli_cumulative_tent_2

# ---------------------------------------------------------------------------
# Feature Engineering — Agronomic Target Ranges
# These drive alert thresholds and reward shaping for the ML models.
# ---------------------------------------------------------------------------
# Vapour Pressure Deficit (kPa) — vegetative phase targets
VPD_TARGET_MIN=0.8
VPD_TARGET_MAX=1.2
# Electrical Conductivity (mS/cm) — nutrient solution
EC_TARGET_MIN=1.8
EC_TARGET_MAX=2.4
# pH — nutrient solution
PH_TARGET_MIN=5.8
PH_TARGET_MAX=6.2
# Daily Light Integral (mol/m²/day) — flowering target
DLI_TARGET=38.0
# CO2 enrichment target (ppm)
CO2_TARGET_PPM=1200
# Substrate volumetric water content (%)
VWC_TARGET_MIN=55
VWC_TARGET_MAX=75

# ---------------------------------------------------------------------------
# Model Registry & Serving
# ---------------------------------------------------------------------------
MODEL_REGISTRY_PATH=/app/models/registry
MODEL_SERVING_TIMEOUT=5.0
PREDICTION_CONFIDENCE_THRESHOLD=0.6
FEATURE_WINDOW_MINUTES=60
INFERENCE_BATCH_SIZE=32

# ---------------------------------------------------------------------------
# Monitoring & Observability
# ---------------------------------------------------------------------------
ENABLE_METRICS=true
METRICS_PORT=9090
DRIFT_ALERT_THRESHOLD=0.15
DRIFT_CHECK_INTERVAL_MINUTES=60
ALERT_EMAIL=engineering@legacyag.co.nz
ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/your/webhook/here

# ---------------------------------------------------------------------------
# Safety / Control (CRITICAL — read before changing)
# ADVISORY_MODE=true means the system recommends actions but does NOT
# actuate any physical devices. Set false only after full validation.
# ---------------------------------------------------------------------------
ADVISORY_MODE=true
MAX_EC_ABSOLUTE=3.5
MAX_TEMP_ABSOLUTE=35.0
MIN_TEMP_ABSOLUTE=15.0
MIN_HUMIDITY_ABSOLUTE=30.0
MAX_HUMIDITY_ABSOLUTE=90.0
CONTROL_RATE_LIMIT_SECONDS=300
EMERGENCY_STOP_ENABLED=true
